---
import BgMedia from './BgMedia.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  poster: string;          // background image (placeholder or your own)
  video?: string | string[];
}

const { eyebrow, title, subtitle, poster, video } = Astro.props;
---

<section class="hero-overlay-media relative flex flex-col items-center justify-center text-center overflow-hidden px-6 py-32 md:py-40">
  <BgMedia
    video={video}
    poster={poster}
    overlay="bg-gradient-to-b from-brown-700/55 via-brown-700/40 to-brown-700/65"
  />

  <div class="relative z-10 max-w-3xl mx-auto">
    {eyebrow && (
      <p class="font-sans text-xs tracking-mega uppercase text-champagne/90 mb-4 animate-fade-in">{eyebrow}</p>
    )}
    <h1 class="font-serif text-4xl md:text-6xl text-cream text-shadow-elegant animate-fade-up">{title}</h1>
    <div class="flex items-center justify-center gap-4 my-6 animate-fade-up" style="animation-delay:0.15s">
      <div class="w-12 h-px bg-gold"></div>
      <span class="text-gold text-sm">&#10022;</span>
      <div class="w-12 h-px bg-gold"></div>
    </div>
    {subtitle && (
      <p class="font-serif text-lg md:text-xl italic text-cream/95 text-shadow-elegant max-w-2xl mx-auto animate-fade-up" style="animation-delay:0.25s">
        {subtitle}
      </p>
    )}
  </div>
</section>
