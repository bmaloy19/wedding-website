---
// RSVPForm.astro — client-side island
// Reads SUPABASE_URL and SUPABASE_ANON_KEY from runtime env vars (injected at build time)
import { parties } from '../data/guests.js';

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL  ?? '';
const supabaseKey  = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<form id="rsvp-form" novalidate class="space-y-8">

  <!-- Name search -->
  <div>
    <label for="guest-search" class="block font-sans text-xs tracking-widest uppercase text-taupe mb-2">
      Find Your Invitation <span class="text-gold">*</span>
    </label>

    <div id="guest-combobox" class="relative">
      <input
        type="text"
        id="guest-search"
        autocomplete="off"
        role="combobox"
        aria-expanded="false"
        aria-controls="guest-list"
        aria-autocomplete="list"
        placeholder="Start typing your name…"
        class="w-full border border-brown-200 bg-ivory px-4 py-3 font-sans text-sm text-brown-600 placeholder-brown-200 focus:outline-none focus:border-brown-400 transition-colors"
      />

      <ul
        id="guest-list"
        role="listbox"
        class="hidden absolute z-20 mt-1 w-full max-h-64 overflow-auto bg-ivory border border-brown-200 shadow-lg"
      >
        {parties.map((p, i) => (
          <li
            role="option"
            data-idx={i}
            data-search={(p.label + ' ' + p.members.join(' ')).toLowerCase()}
            class="guest-option px-4 py-2.5 font-sans text-sm text-brown-600 cursor-pointer hover:bg-brown-100 aria-selected:bg-brown-100"
          >
            {p.label}
          </li>
        ))}
        <li id="guest-empty" class="hidden px-4 py-2.5 font-sans text-sm text-taupe italic">
          No matching name found.
        </li>
      </ul>
    </div>

    <p class="font-sans text-xs text-taupe mt-1">
      Search by any name on your invitation. Can't find it?
      <a href="mailto:bmaloy19@gmail.com" class="underline hover:text-brown-500 transition-colors">Let us know</a>.
    </p>
  </div>

  <!-- Attendance (revealed & built once an invitation is chosen) -->
  <div id="attendance" class="hidden space-y-4">
    <div>
      <p class="font-sans text-xs tracking-widest uppercase text-taupe mb-1">
        Attendance <span class="text-gold">*</span>
      </p>
      <p class="font-sans text-xs text-taupe">
        Check the days each guest will attend. Leave both unchecked for anyone who sadly can't make it.
      </p>
    </div>
    <div id="party-members" class="space-y-3"></div>
  </div>

  <!-- Error message -->
  <p id="form-error" class="hidden font-sans text-sm text-red-500"></p>

  <!-- Submit -->
  <div id="submit-wrap" class="hidden text-center pt-2">
    <button
      type="submit"
      id="submit-btn"
      class="btn-primary min-w-[200px]"
    >
      Send My RSVP
    </button>
  </div>

</form>

<!-- Success state -->
<div id="rsvp-success" class="hidden text-center py-12">
  <div class="flex items-center justify-center gap-4 mb-6">
    <div class="w-12 h-px bg-gold opacity-60"></div>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-gold">
      <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
    </svg>
    <div class="w-12 h-px bg-gold opacity-60"></div>
  </div>
  <h2 class="font-serif text-3xl text-brown-600 italic mb-4">Thank You!</h2>
  <p class="font-sans text-base text-taupe max-w-md mx-auto leading-relaxed">
    Your RSVP has been received. We are so grateful — and we simply cannot wait
    to celebrate with you.
  </p>
</div>

<script define:vars={{ supabaseUrl, supabaseKey, parties }}>
  const form        = document.getElementById('rsvp-form');
  const successEl   = document.getElementById('rsvp-success');
  const errorEl     = document.getElementById('form-error');
  const submitBtn   = document.getElementById('submit-btn');
  const submitWrap  = document.getElementById('submit-wrap');

  // Combobox
  const search      = document.getElementById('guest-search');
  const listEl      = document.getElementById('guest-list');
  const emptyEl     = document.getElementById('guest-empty');
  const options     = Array.from(listEl.querySelectorAll('.guest-option'));

  // Conditionally-shown sections
  const attendance  = document.getElementById('attendance');
  const membersWrap = document.getElementById('party-members');

  let selected   = null; // the chosen party object
  let activeIndex = -1;   // keyboard-highlighted visible option

  // ── Combobox behaviour ──────────────────────────────────────────────
  const openList  = () => { filterOptions(); listEl.classList.remove('hidden'); search.setAttribute('aria-expanded', 'true'); };
  const closeList = () => { listEl.classList.add('hidden'); search.setAttribute('aria-expanded', 'false'); setActive(-1); };
  const visibleOptions = () => options.filter(o => !o.classList.contains('hidden'));

  function filterOptions() {
    const q = search.value.trim().toLowerCase();
    let anyVisible = false;
    options.forEach(o => {
      const match = o.dataset.search.includes(q);
      o.classList.toggle('hidden', !match);
      if (match) anyVisible = true;
    });
    emptyEl.classList.toggle('hidden', anyVisible);
    setActive(-1);
  }

  function setActive(i) {
    const vis = visibleOptions();
    options.forEach(o => o.removeAttribute('aria-selected'));
    activeIndex = i;
    if (i >= 0 && i < vis.length) {
      vis[i].setAttribute('aria-selected', 'true');
      vis[i].scrollIntoView({ block: 'nearest' });
    }
  }

  function selectParty(optionEl) {
    selected = parties[Number(optionEl.dataset.idx)];
    search.value = selected.label;
    closeList();
    buildAttendance(selected);
    attendance.classList.remove('hidden');
    submitWrap.classList.remove('hidden');
    errorEl.classList.add('hidden');
  }

  function clearSelection() {
    selected = null;
    membersWrap.innerHTML = '';
    attendance.classList.add('hidden');
    submitWrap.classList.add('hidden');
  }

  // ── Build the per-person attendance rows ────────────────────────────
  function buildAttendance(party) {
    membersWrap.innerHTML = '';
    party.members.forEach(name => membersWrap.appendChild(makeRow(name, false)));
    for (let k = 0; k < (party.extraGuests || 0); k++) {
      membersWrap.appendChild(makeRow('', true));
    }
  }

  function makeRow(name, isPlusOne) {
    const row = document.createElement('div');
    row.className = 'attend-row border border-brown-100 bg-white p-4';
    row.dataset.plusone = isPlusOne ? 'true' : 'false';

    if (isPlusOne) {
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'plusone-name w-full border border-brown-200 bg-ivory px-3 py-2 font-sans text-sm text-brown-600 placeholder-brown-200 focus:outline-none focus:border-brown-400 transition-colors';
      input.placeholder = 'Additional guest — name (optional)';
      row.appendChild(input);
    } else {
      const p = document.createElement('p');
      p.className = 'attend-name font-serif text-lg text-brown-600';
      p.textContent = name;
      row.appendChild(p);
    }

    const days = document.createElement('div');
    days.className = 'flex flex-wrap gap-6 mt-3';
    [['1', 'Friday, Nov 19'], ['2', 'Saturday, Nov 20']].forEach(([d, lbl]) => {
      const label = document.createElement('label');
      label.className = 'flex items-center gap-2 cursor-pointer';
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.className = 'attend-day accent-brown-500';
      cb.dataset.day = d;
      const span = document.createElement('span');
      span.className = 'font-sans text-sm text-brown-600';
      span.textContent = lbl;
      label.append(cb, span);
      days.appendChild(label);
    });
    row.appendChild(days);

    const diet = document.createElement('input');
    diet.type = 'text';
    diet.className = 'attend-diet w-full border border-brown-200 bg-ivory px-3 py-2 mt-3 font-sans text-sm text-brown-600 placeholder-brown-200 focus:outline-none focus:border-brown-400 transition-colors';
    diet.placeholder = 'Dietary restrictions or allergies (optional)';
    row.appendChild(diet);

    return row;
  }

  // ── Combobox events ─────────────────────────────────────────────────
  search.addEventListener('focus', openList);
  search.addEventListener('input', () => {
    if (selected && search.value !== selected.label) clearSelection();
    openList();
  });
  search.addEventListener('keydown', (e) => {
    const vis = visibleOptions();
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (listEl.classList.contains('hidden')) openList();
      setActive(Math.min(activeIndex + 1, vis.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIndex - 1, 0));
    } else if (e.key === 'Enter') {
      if (!listEl.classList.contains('hidden') && activeIndex >= 0 && vis[activeIndex]) {
        e.preventDefault();
        selectParty(vis[activeIndex]);
      }
    } else if (e.key === 'Escape') {
      closeList();
    }
  });
  options.forEach(o => o.addEventListener('mousedown', (e) => { e.preventDefault(); selectParty(o); }));
  document.addEventListener('click', (e) => {
    if (!document.getElementById('guest-combobox').contains(e.target)) closeList();
  });

  // ── Submit ──────────────────────────────────────────────────────────
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    errorEl.textContent = '';

    if (!selected) {
      showError('Please find and select your invitation from the list.');
      return;
    }

    const records = [];

    for (const row of membersWrap.querySelectorAll('.attend-row')) {
      const isPlus = row.dataset.plusone === 'true';
      const day1 = row.querySelector('.attend-day[data-day="1"]').checked;
      const day2 = row.querySelector('.attend-day[data-day="2"]').checked;

      let name;
      if (isPlus) {
        name = row.querySelector('.plusone-name').value.trim();
        if (!name) {
          if (day1 || day2) {
            showError('Please enter a name for the additional guest, or uncheck their days.');
            return;
          }
          continue; // empty plus-one slot — skip it
        }
      } else {
        name = row.querySelector('.attend-name').textContent;
      }

      const dietary = row.querySelector('.attend-diet').value.trim() || null;
      records.push({ party: selected.label, name, day1, day2, dietary });
    }

    submitBtn.textContent = 'Sending…';
    submitBtn.disabled = true;

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/rsvps`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(records),
      });

      if (!res.ok) {
        const err = await res.text();
        throw new Error(err || `HTTP ${res.status}`);
      }

      form.classList.add('hidden');
      successEl.classList.remove('hidden');

    } catch (err) {
      showError('Something went wrong — please try again or email us directly.');
      console.error(err);
    }
  });

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
    submitBtn.textContent = 'Send My RSVP';
    submitBtn.disabled = false;
  }
</script>
