    <p class="font-sans font-light text-xs text-brown-300/70">
      Questions? Reach us at <a href="mailto:bmaloy19@gmail.com" class="underline underline-offset-4 decoration-gold/40 hover:text-champagne transition-colors">bmaloy19@gmail.com</a>
    </p>
  </div>
