  <div class="max-w-4xl mx-auto px-6 text-center">

    <p class="eyebrow text-gold/80 mb-6">Forever begins</p>
    <p class="font-script text-5xl md:text-6xl text-champagne mb-6">Kacey &amp; Bryce</p>

    <div class="flex items-center justify-center gap-4 mb-8">
      <span class="block h-px w-16 bg-gradient-to-r from-transparent to-gold/50"></span>
      <span class="text-gold/80 text-xs">&#10022;</span>
      <span class="block h-px w-16 bg-gradient-to-l from-transparent to-gold/50"></span>
