    <p class="font-serif text-lg tracking-[0.2em] uppercase text-champagne/70 mb-10">
      November 19, 2027 &nbsp;&middot;&nbsp; Des Moines, Iowa
    </p>

    <nav class="flex flex-wrap justify-center gap-x-10 gap-y-4 mb-12">
      {[
        { href: '/',          label: 'Home'      },
        { href: '/details',  label: 'Details'   },
        { href: '/travel',   label: 'Travel'    },
        { href: '/registry', label: 'Registry'  },
        { href: '/rsvp',     label: 'RSVP'      },
