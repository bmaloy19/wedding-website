---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

// Our favorite spots around town
const favorites = [
  {
    type: 'Coffee',
    name: 'Northern Vessel',
    desc: 'Our favorite coffee shop — where slow mornings happen.',
  },
  {
    type: 'Date Night',
    name: 'Cosi Cucina',
    desc: 'Our go-to date-night spot.',
  },
  {
    type: 'Drinks',
    name: 'Exile Brewery',
    desc: 'One of our favorite local breweries.',
  },
];

---

<Layout
  title="Stay Awhile — Kacey & Bryce"
  description="Our favorite spots around Des Moines, Iowa — make a weekend of it."
>

  <!-- Hero -->
  <PageHero
    eyebrow="Des Moines, Iowa"
    title="Stay Awhile"
    subtitle="Where we'd spend a Saturday."
    poster="/images/IMG_0457.JPG"
    posterPosition="center 35%"
  />

  <!-- Our favorite spots -->
  <section class="py-24 px-6 max-w-3xl mx-auto">
    <div data-reveal>
      <p class="eyebrow text-center mb-4">A few of our favorites</p>
      <h2 class="section-title">Our Favorite Spots</h2>
      <p class="font-serif text-xl italic text-brown-400 text-center max-w-xl mx-auto mt-8 mb-4 leading-relaxed">
        If you're staying the weekend, here's where you'll find us.
      </p>
    </div>

    <div class="mt-14 space-y-6">
      {favorites.map((item, i) => (
        <div
          class="group frame-luxe !p-8 md:!p-10 flex flex-col md:flex-row md:items-baseline gap-2 md:gap-10 transition-all duration-500 ease-luxe hover:-translate-y-1 hover:shadow-[0_20px_50px_-24px_rgba(42,27,16,0.25)]"
          data-reveal
          style={`transition-delay:${i * 0.1}s`}
        >
          <p class="eyebrow shrink-0 md:w-28">{item.type}</p>
          <div>
            <h3 class="font-serif font-medium text-3xl text-brown-600 mb-2 transition-colors group-hover:text-brown-500">{item.name}</h3>
            <p class="font-serif text-lg italic text-brown-400 leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>


</Layout>
