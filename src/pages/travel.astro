---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const hotels = [
  {
    name: '[Hotel Name]',
    note: 'Preferred — Room Block Available',
    address: '[Address], Des Moines, IA',
    phone: '[Phone]',
    code: 'MALOY2027',
    deadline: 'October 19, 2027',
    link: '#',
  },
  {
    name: '[Hotel Name 2]',
    note: 'Nearby Option',
    address: '[Address], Des Moines, IA',
    phone: '[Phone]',
    code: null,
    deadline: null,
    link: '#',
  },
];

const gettingHere = [
  {
    numeral: 'I',
    title: 'By Air',
    body: 'Fly into Des Moines International Airport (DSM), approximately 20 minutes from the venue. Major airlines serve DSM with connections from most U.S. hubs.',
  },
  {
    numeral: 'II',
    title: 'By Car',
    body: 'Des Moines sits at the intersection of I-80 and I-35, making it easily accessible from across the Midwest. Ample parking will be available at the venue — details to follow.',
  },
  {
    numeral: 'III',
    title: 'Rideshare',
    body: 'Uber and Lyft are both available in Des Moines and are a wonderful option for getting to and from events — especially on the evening of the reception.',
  },
];
---

<Layout
  title="Travel & Stay — Kacey & Bryce"
  description="Travel information and hotel recommendations for our wedding in Des Moines, Iowa."
>

  <!-- Hero -->
  <PageHero
    eyebrow="We can't wait to welcome you"
    title="Travel & Stay"
    subtitle="Des Moines is a warm and welcoming city — and we have done our best to make your journey here as effortless as possible."
    poster="https://picsum.photos/seed/maloy-travel/1920/1080?grayscale"
  />

  <!-- Getting here -->
  <section class="py-24 px-6 max-w-5xl mx-auto">
    <div data-reveal>
      <p class="eyebrow text-center mb-4">The journey</p>
      <h2 class="section-title">Getting Here</h2>
      <div class="section-divider"><span class="gem"></span></div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mt-12">
      {gettingHere.map((item, i) => (
        <div class="card card-hover text-center" data-reveal style={`transition-delay:${i * 0.1}s`}>
          <p class="font-serif text-2xl text-gold/70 mb-1">{item.numeral}</p>
          <div class="w-8 h-px bg-gold/40 mx-auto mb-6"></div>
          <h3 class="font-serif font-medium text-2xl text-brown-600 mb-4">{item.title}</h3>
          <p class="font-sans font-light text-sm text-taupe leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Hotel blocks -->
  <section class="pb-24 px-6 max-w-5xl mx-auto">
    <div data-reveal>
      <p class="eyebrow text-center mb-4">Rest well</p>
      <h2 class="section-title">Where to Stay</h2>
      <div class="section-divider"><span class="gem"></span></div>
      <p class="font-serif text-xl italic text-brown-400 text-center max-w-xl mx-auto mb-14 leading-relaxed">
        We have reserved room blocks at the hotels below for our guests.
        We recommend booking early — rooms are limited.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {hotels.map((hotel, i) => (
        <div class="frame-luxe flex flex-col" data-reveal style={`transition-delay:${i * 0.1}s`}>
          <p class="eyebrow mb-2">{hotel.note}</p>
          <h3 class="font-serif font-medium text-3xl text-brown-600 mb-2">{hotel.name}</h3>
          <p class="font-sans font-light text-sm text-taupe mb-6">{hotel.address}</p>

          {hotel.code && (
            <div class="border-t border-b border-gold/30 py-4 mb-6 text-center">
              <p class="font-sans font-normal text-[0.6rem] tracking-mega uppercase text-taupe mb-1">Group code</p>
              <p class="font-serif font-medium text-2xl tracking-[0.15em] text-gold">{hotel.code}</p>
              <p class="font-sans font-light text-xs text-taupe mt-1">Book by {hotel.deadline}</p>
            </div>
          )}

          <a href={hotel.link} class="btn-outline text-center block mt-auto">Reserve a Room</a>
        </div>
      ))}
    </div>
  </section>

  <!-- Things to do -->
  <section class="py-24 bg-cream px-6 text-center relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 max-w-xl h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div data-reveal>
      <p class="eyebrow mb-4">Make a weekend of it</p>
      <h2 class="section-title">While You're in Des Moines</h2>
      <div class="section-divider"><span class="gem"></span></div>
      <p class="font-serif text-xl italic text-brown-400 max-w-2xl mx-auto leading-relaxed mb-14">
        Des Moines has wonderful restaurants, art galleries, and the beautiful
        Principal Riverwalk — perfect for a crisp November stroll with a warm coffee in hand.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto text-left">
      {[
        { name: 'Pappajohn Sculpture Park',  type: 'Art & Culture',   desc: 'A stunning outdoor gallery in the heart of downtown.'       },
        { name: 'East Village',               type: 'Food & Drink',    desc: 'Charming boutiques, cafés, and acclaimed restaurants.'      },
        { name: 'Iowa State Capitol',         type: 'Landmark',        desc: 'One of the most beautiful capitol buildings in the country.' },
      ].map((item, i) => (
        <div class="card card-hover" data-reveal style={`transition-delay:${i * 0.1}s`}>
          <p class="eyebrow mb-2">{item.type}</p>
          <h3 class="font-serif font-medium text-2xl text-brown-600 mb-2">{item.name}</h3>
          <p class="font-sans font-light text-sm text-taupe leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

</Layout>
