---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const registries = [
  {
    name: '[Registry Name]',
    description: 'Home, kitchen, and everyday living.',
    link: '#',
    linkText: 'View Registry',
  },
  {
    name: '[Registry Name 2]',
    description: 'For adventures and experiences together.',
    link: '#',
    linkText: 'View Registry',
  },
  {
    name: 'Honeymoon Fund',
    description: 'Contribute toward our honeymoon.',
    link: '#',
    linkText: 'Contribute',
  },
];
---

<Layout
  title="A Few Things We Love — Kacey & Bryce"
  description="A few things that would help us begin this next chapter together."
>

  <!-- Hero -->
  <PageHero
    eyebrow="Thank you"
    title="A Few Things We Love"
    subtitle="Your presence is the greatest gift of all."
    poster="/images/IMG_0452.JPG"
  />

  <!-- Note -->
  <section class="py-24 px-6 max-w-2xl mx-auto text-center" data-reveal>
    <p class="font-serif text-3xl md:text-4xl italic text-brown-500 leading-relaxed mb-8">
      The greatest gift is having our favorite people in one room, celebrating right alongside us.
    </p>
    <p class="font-sans font-light text-base text-brown-400 leading-relaxed">
      If you'd like to bless us beyond your presence, we've put together a registry
      with a few things to help us start this next chapter together.
    </p>
  </section>

  <!-- Registry cards -->
  <section class="pb-28 px-6 max-w-4xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8">
      {registries.map((r, i) => (
        <div class="card card-hover text-center flex flex-col justify-between" data-reveal style={`transition-delay:${i * 0.1}s`}>
          <div>
            <div class="w-8 h-px bg-gold/40 mx-auto mb-6"></div>
            <h3 class="font-serif font-medium text-2xl text-brown-600 mb-3">{r.name}</h3>
            <p class="font-sans font-light text-sm text-taupe leading-relaxed mb-8">{r.description}</p>
          </div>
          <a href={r.link} class="btn-outline">{r.linkText}</a>
        </div>
      ))}
    </div>
  </section>

  <!-- Closing sentiment -->
  <section class="py-20 bg-cream text-center px-6 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 max-w-xl h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <p class="font-serif text-2xl italic text-brown-400 max-w-xl mx-auto leading-relaxed" data-reveal>
      Thank you — we can't wait to celebrate with you.
    </p>
  </section>

</Layout>
