---
import Layout from '../layouts/Layout.astro';
import BgMedia from '../components/BgMedia.astro';

const heroPoster = '/images/IMG_4708.JPG';

const quickLinks = [
  { href: '/details',  numeral: 'I',   title: 'Details',  desc: 'The schedule for both days, plus what to wear.' },
  { href: '/travel',   numeral: 'II',  title: 'Travel',   desc: 'Flights, hotels, and getting around Des Moines.' },
  { href: '/registry', numeral: 'III', title: 'Registry', desc: 'A few ideas, for those who have asked.' },
];
---

<Layout title="Kacey & Bryce — November 19, 2027">

  <!-- Hero -->
  <section class="hero-overlay-media relative min-h-screen -mt-[81px] flex flex-col items-center justify-center text-center overflow-hidden px-6">

    <BgMedia
      poster={heroPoster}
      overlay="bg-gradient-to-b from-ink/70 via-ink/35 to-ink/80"
    />

    <!-- Decorative double-hairline corner flourishes -->
    <div class="absolute top-10 left-10 w-24 h-24 border-t border-l border-champagne/40 z-10 hidden sm:block">
      <div class="absolute top-1.5 left-1.5 w-full h-full border-t border-l border-champagne/25"></div>
    </div>
    <div class="absolute top-10 right-10 w-24 h-24 border-t border-r border-champagne/40 z-10 hidden sm:block">
      <div class="absolute top-1.5 right-1.5 w-full h-full border-t border-r border-champagne/25"></div>
    </div>
    <div class="absolute bottom-10 left-10 w-24 h-24 border-b border-l border-champagne/40 z-10 hidden sm:block">
      <div class="absolute bottom-1.5 left-1.5 w-full h-full border-b border-l border-champagne/25"></div>
    </div>
    <div class="absolute bottom-10 right-10 w-24 h-24 border-b border-r border-champagne/40 z-10 hidden sm:block">
      <div class="absolute bottom-1.5 right-1.5 w-full h-full border-b border-r border-champagne/25"></div>
    </div>

    <div class="relative z-10 flex flex-col items-center">
      <p class="eyebrow text-champagne/90 mb-8 animate-fade-in">The Wedding Of</p>

      <h1 class="font-script text-7xl md:text-9xl text-cream leading-none mb-4 text-shadow-elegant animate-fade-up">
        Kacey <span class="text-[0.7em] align-middle -ml-[0.35em]">&amp;</span> Bryce
      </h1>

      <div class="flex items-center gap-5 my-8 animate-fade-up" style="animation-delay:0.2s">
        <div class="h-px w-20 bg-gradient-to-r from-transparent to-gold"></div>
        <span class="text-gold text-sm">&#10022;</span>
        <div class="h-px w-20 bg-gradient-to-l from-transparent to-gold"></div>
      </div>

      <p class="font-serif font-medium text-2xl md:text-3xl tracking-[0.25em] uppercase text-cream mb-3 text-shadow-elegant animate-fade-up" style="animation-delay:0.3s">
        November 19, 2027
      </p>
      <p class="eyebrow text-champagne/80 mb-12 animate-fade-up" style="animation-delay:0.4s">
        Des Moines &middot; Iowa
      </p>

    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-fade-in" style="animation-delay:1.4s">
      <span class="block w-px h-12 bg-gradient-to-b from-champagne/0 via-champagne/50 to-champagne/0 mx-auto"></span>
    </div>
  </section>

  <!-- Quick links -->
  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      {quickLinks.map((card, i) => (
        <a href={card.href} class="card group text-center" data-reveal style={`transition-delay:${i * 0.1}s`}>
          <p class="font-serif text-2xl text-gold/70 mb-1">{card.numeral}</p>
          <div class="w-8 h-px bg-gold/40 mx-auto mb-6 transition-all duration-500 ease-luxe group-hover:w-16 group-hover:bg-gold"></div>
          <h3 class="font-serif font-medium text-2xl text-brown-600 mb-3 transition-colors group-hover:text-brown-500">{card.title}</h3>
          <p class="font-sans font-light text-sm text-taupe leading-relaxed mb-6">{card.desc}</p>
          <span class="font-sans font-normal text-[0.6rem] tracking-mega uppercase text-gold opacity-0 -translate-y-1 transition-all duration-500 ease-luxe group-hover:opacity-100 group-hover:translate-y-0">
            Discover &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>

</Layout>
