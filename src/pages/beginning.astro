---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const story = [
  "Credit where credit is due... thanks, Tinder.",
  "We met during college, and somehow Kacey ended up paying for our first date—a story Bryce has yet to live down (and probably never will).",
  "Somewhere between then and now, we found a rhythm that just works. Kacey became Bryce's biggest cheerleader—learning how to cook beef exactly the way he likes it, weighing rice with surprising precision, turning the kitchen into a barber shop, celebrating every win (big or small), and making even the most ordinary evenings feel like home.",
  "Meanwhile, Bryce became Kacey's steady constant. From surprise coffee runs and patiently explaining the difference between John Wayne and Dwayne Johnson more times than anyone should have to, to making sure her gas tank is never running on empty and never saying no to a project he somehow got volunteered for, he's been the first to jump in, lend a hand, and support every dream she chases.",
  "It's never really been about the grand gestures. It's the little things. The quiet routines. The grocery store trips. The \"drive safe\" texts. The endless errands. The way one of us is always willing to do something simply because it makes the other person's day a little easier.",
  "Since then, we've built a life filled with ordinary days that became extraordinary simply because we were together. And now, we're so excited to celebrate the next chapter with all of you.",
];
---

<Layout
  title="The Beginning — Kacey & Bryce"
  description="How Bryce and Kacey found their way to forever."
>

  <!-- Hero -->
  <PageHero
    eyebrow="Our Story"
    title="The Beginning"
    subtitle="Somewhere between then and forever."
    poster="/images/IMG_4704.JPG"
    posterPosition="center 30%"
  />

  <!-- Story -->
  <section class="py-24 px-6 max-w-2xl mx-auto">
    <div data-reveal>
      <p class="eyebrow text-center mb-4">Where it started</p>
      <h2 class="section-title">How We Met</h2>
      <div class="section-divider"><span class="gem"></span></div>
    </div>

    <div class="mt-12 space-y-8">
      {story.map((para, i) => (
        <p
          class="font-serif text-xl md:text-2xl text-brown-500 leading-relaxed text-center"
          data-reveal
          style={`transition-delay:${i * 0.1}s`}
        >
          {para}
        </p>
      ))}
    </div>
  </section>

  <!-- Closing -->
  <section class="py-20 bg-cream text-center px-6 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 max-w-xl h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <p class="font-serif text-2xl md:text-3xl italic text-brown-400 max-w-xl mx-auto leading-relaxed" data-reveal>
      And the best part is still to come.
    </p>
  </section>

</Layout>
