---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Our Story — Kacey & Bryce"
  description="The story of how Bryce and Kacey fell in love."
>

  <!-- Page hero -->
  <PageHero
    eyebrow="A love story"
    title="Our Story"
    subtitle="Every great love begins with a single, unforgettable moment."
    poster="https://picsum.photos/seed/maloy-story/1920/1080?grayscale"
  />

  <!-- Timeline -->
  <section class="py-20 px-6 max-w-3xl mx-auto">

    <!-- Chapter 1 -->
    <div class="mb-20">
      <p class="font-sans text-xs tracking-widest uppercase text-gold mb-2">How We Met</p>
      <h2 class="font-serif text-3xl text-brown-600 italic mb-6">The Beginning</h2>
      <p class="font-sans text-base text-brown-500 leading-relaxed mb-4">
        [Share the story of how you met here — the setting, the moment, what you noticed first about each other.
        Was it a chance encounter, a mutual friend, or something entirely unexpected?
        Let your guests feel the warmth of that first spark.]
      </p>
      <p class="font-sans text-base text-brown-500 leading-relaxed">
        [Continue with what made that first meeting memorable. Every detail matters — the laughter,
        the nervousness, the quiet realization that something extraordinary had just begun.]
      </p>
    </div>

    <div class="w-px h-16 bg-brown-200 mx-auto mb-16"></div>

    <!-- Chapter 2 -->
    <div class="mb-20">
      <p class="font-sans text-xs tracking-widest uppercase text-gold mb-2">Falling in Love</p>
      <h2 class="font-serif text-3xl text-brown-600 italic mb-6">The Middle</h2>
      <p class="font-sans text-base text-brown-500 leading-relaxed mb-4">
        [Describe the journey of falling in love — the adventures you shared, the ordinary moments
        that became extraordinary simply because you were together. The late nights, the road trips,
        the quiet mornings that felt like the whole world.]
      </p>
      <p class="font-sans text-base text-brown-500 leading-relaxed">
        [What was the moment you knew? Share the feeling of certainty — that quiet, beautiful knowing
        that this person was home.]
      </p>
    </div>

    <div class="w-px h-16 bg-brown-200 mx-auto mb-16"></div>

    <!-- Chapter 3 — The Proposal -->
    <div class="mb-20">
      <p class="font-sans text-xs tracking-widest uppercase text-gold mb-2">The Proposal</p>
      <h2 class="font-serif text-3xl text-brown-600 italic mb-6">She Said Yes</h2>
      <p class="font-sans text-base text-brown-500 leading-relaxed mb-4">
        [Tell the proposal story — where, when, and how. The careful planning, the happy tears,
        the moment time seemed to stand still. Let your guests relive the joy of that yes
        alongside you.]
      </p>
      <p class="font-sans text-base text-brown-500 leading-relaxed">
        [And now, we get to celebrate. We cannot imagine a more beautiful next chapter,
        and we are so grateful to share it with every one of you.]
      </p>
    </div>

  </section>

  <!-- Photo grid placeholder -->
  <section class="pb-24 px-6 max-w-5xl mx-auto">
    <h2 class="section-title mb-4">Moments</h2>
    <div class="section-divider"></div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {Array.from({ length: 6 }).map((_, i) => (
        <div class="group relative aspect-square overflow-hidden bg-brown-100">
          <img
            src={`https://picsum.photos/seed/maloy-moment-${i + 1}/800/800`}
            alt={`A favourite moment, number ${i + 1}`}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 ring-1 ring-inset ring-gold/20"></div>
        </div>
      ))}
    </div>
    <p class="text-center font-sans text-xs text-taupe mt-6">
      <!-- Placeholder imagery — replace the picsum.photos src above with your own photos -->
      A glimpse of us — more to come
    </p>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-parchment text-center px-6">
    <p class="font-serif text-2xl italic text-brown-500 mb-6">
      We hope you can join us as our story continues.
    </p>
    <a href="/rsvp" class="btn-primary">RSVP Now</a>
  </section>

</Layout>
