---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const days = [
  {
    day: 'Day One',
    numeral: 'I',
    date: 'Friday, November 19, 2027',
    label: 'Rehearsal & Welcome Dinner',
    tagline: 'An evening with family and friends before the big day.',
    events: [
      { time: '5:00 PM', name: 'Rehearsal', detail: '[Ceremony Venue], Des Moines, IA' },
      { time: '7:00 PM', name: 'Welcome Dinner', detail: '[Dinner Venue] — dress code: cocktail attire' },
      { time: '9:00 PM', name: 'Evening Reception', detail: 'Dancing, toasts & celebration' },
    ],
  },
  {
    day: 'Day Two',
    numeral: 'II',
    date: 'Saturday, November 20, 2027',
    label: 'Ceremony & Reception',
    tagline: 'The main event — ceremony, dinner, and dancing.',
    events: [
      { time: '4:00 PM', name: 'Doors Open', detail: 'Guests welcome to be seated' },
      { time: '4:30 PM', name: 'Ceremony', detail: '[Ceremony Venue], Des Moines, IA' },
      { time: '5:30 PM', name: 'Cocktail Hour', detail: '[Venue] — garden terrace' },
      { time: '7:00 PM', name: 'Dinner & Reception', detail: '[Reception Venue]' },
      { time: '11:00 PM', name: 'Send-off', detail: 'Farewell & sparkler exit' },
    ],
  },
];
---

<Layout
  title="Wedding Details — Kacey & Bryce"
  description="All the details for our two-day celebration in Des Moines, Iowa."
>

  <!-- Hero -->
  <PageHero
    eyebrow="November 19–20, 2027"
    title="Details"
    subtitle="Everything you need to know about the weekend."
    poster="https://picsum.photos/seed/maloy-celebration/1920/1080?grayscale"
  />

  <!-- Day cards -->
  <section class="py-24 px-6 max-w-5xl mx-auto space-y-24">
    {days.map((d, idx) => (
      <div class:list={['grid gap-12 items-start', idx % 2 !== 0 ? 'md:grid-cols-[2fr_1fr]' : 'md:grid-cols-[1fr_2fr]']} data-reveal>

        <!-- Label side -->
        <div class:list={['md:text-right', idx % 2 !== 0 ? 'md:order-last md:text-left' : '']}>
          <p class="font-serif text-5xl text-gold/40 leading-none mb-3">{d.numeral}</p>
          <p class="eyebrow mb-3">{d.day}</p>
          <h2 class="font-serif font-medium text-3xl md:text-4xl text-brown-600 italic mb-3 leading-snug">{d.label}</h2>
          <p class="font-sans font-normal text-[0.65rem] tracking-mega uppercase text-taupe mb-4">{d.date}</p>
          <p class="font-serif text-lg italic text-brown-400 leading-relaxed">{d.tagline}</p>
        </div>

        <!-- Timeline -->
        <div class="frame-luxe !p-0 overflow-hidden">
          <div class="relative py-4">
            {d.events.map((event, i) => (
              <div class:list={[
                'relative flex items-start gap-8 px-8 md:px-12 py-6',
                i < d.events.length - 1 ? 'border-b border-brown-100/70' : '',
              ]}>
                <span class="font-serif font-medium text-lg text-gold whitespace-nowrap w-24 shrink-0 text-right">
                  {event.time}
                </span>
                <span class="text-gold/60 text-[0.6rem] pt-2 shrink-0">&#9670;</span>
                <div>
                  <p class="font-serif font-medium text-2xl text-brown-600 leading-tight">{event.name}</p>
                  <p class="font-sans font-light text-sm text-taupe mt-1">{event.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    ))}
  </section>

  <!-- Dress code note -->
  <section class="py-20 bg-cream text-center px-6 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 max-w-xl h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
    <div data-reveal>
      <p class="eyebrow mb-4">What to wear</p>
      <h2 class="font-serif font-medium text-4xl text-brown-600 mb-2">Attire</h2>
      <div class="section-divider"><span class="gem"></span></div>
      <p class="font-serif text-xl italic text-brown-500 max-w-xl mx-auto leading-relaxed mb-4">
        Cocktail or formal attire.
      </p>
      <p class="font-sans font-light text-sm text-brown-400 max-w-lg mx-auto leading-relaxed">
        Neutrals, creams, and warm earth tones fit the setting, but wear whatever
        you feel good in. Please save white and ivory for the bride.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center px-6" data-reveal>
    <p class="font-serif text-3xl md:text-4xl italic text-brown-500 mb-10">
      We hope you can join us.
    </p>
    <a href="/rsvp" class="btn-primary">RSVP</a>
  </section>

</Layout>
