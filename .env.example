# Supabase — get these from your Supabase project dashboard
# Settings → API → Project URL and anon/public key
#
# These must be prefixed with PUBLIC_ so Astro exposes them to client-side scripts.
# Add them as Environment Variables in your Netlify site settings too.

PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
